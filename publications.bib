@report{haslbeck_testing_2023,
	title = {Testing for Group Differences in Multilevel Vector Autoregressive Models},
	url = {https://osf.io/dhp8s},
	abstract = {Multilevel Vector Autoregressive ({VAR}) models have become a popular tool for analyzing time series data of multiple subjects. Many studies aim to investigate differences in multilevel {VAR} models between groups, such as patients and control. However, there is currently no easily applicable method to make inferences about such group differences. Here, we present two tests for making such inference: a standard parametric test and a nonparametric permutation test. We explain the rationale for both tests, provide an implementation in an R-package, and use a simulation study to evaluate their performance in recovering group differences in scenarios resembling empirical research. Finally, we provide a fully reproducible R-tutorial on testing group differences in a dataset of emotion measures using the new R-package mnet.},
	institution = {{PsyArXiv}},
	type = {preprint},
	author = {Haslbeck, Jonas M B and Epskamp, Sacha and Waldorp, Lourens},
	urldate = {2024-03-04},
	date = {2023-06-15},
	langid = {english},
	doi = {10.31234/osf.io/dhp8s},
