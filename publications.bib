	keywords = {Schools, Experimentation, Alcohol Use, Adolescent Development, Choice Behavior, Developmental Stages, Drug Usage, Emerging Adulthood, Intergroup Dynamics, Peers, Psychosocial Factors, Social Influences, Socialization, Substance Use Prevention, Tobacco Smoking},
	file = {Snapshot:C\:\\Users\\d497j944\\Zotero\\storage\\4Z8QT2T5\\2009-19890-020.html:text/html},
}

@article{loke_family_2013,
