@article{emmons_tobacco_1997,
	title = {{TOBACCO} {CONTROL}:: A Brief Review of its History and Prospects for the Future},
	volume = {11},
	issn = {0889-8588},
	url = {https://www.sciencedirect.com/science/article/pii/S0889858805704251},
	doi = {10.1016/S0889-8588(05)70425-1},
	shorttitle = {{TOBACCO} {CONTROL}},
	abstract = {Substantial gains have been made in reducing smoking prevalence in the United States. Prevalence among men has dropped sharply over the past 3 decades, although the declines among women have been slower and less dramatic. 37 Population-based estimates suggest that 23\% to 25.5\% of the {US} population currently smokes, as compared with over 40\% in 1965. 37, 38, 64, 65 Although the reduction in overall smoking prevalence represents a major victory for public health, there are many groups within the population that have not experienced these gains. For example, low socioeconomic status and low educational attainment are now the primary predictors of smoking status in the United States. 29, 32, 75 Furthermore, there has been relatively little reduction in the overall rates of smoking initiation among adolescents over the past 10 years, despite aggressive prevention campaigns. 18 These data suggest that, although there have been some important strides made in the reduction of smoking among the {US} population, there are important target groups that continue to smoke at disproportionately high rates, and that have been less likely to experience the benefits of tobacco control efforts. Furthermore, the significant reductions in smoking prevalence that have occurred have been in an era when tremendous effort and resources have been expended in the area of tobacco control; however, these resources are increasingly being targeted by both the tobacco industry and legislators who seek to divert tobacco control set-aside funds for other uses. The shrinkage of resources for tobacco control threatens the gains that have been made in reducing smoking prevalence. It is therefore critical that public health advocates look to the past as part of their efforts to plan effective tobacco control strategies for the next decade. The issues facing tobacco control advocates are complex. The goals of this article are to (1) highlight a few key events in the history of tobacco control and discuss their implications for future tobacco control initiatives, and (2) to look toward the future of tobacco control to identify efforts that are likely to have maximal public health impact. This article is not intended as an exhaustive review but is an effort to illustrate the impact of some key tobacco control strategies, and to identify issues that may be important in the next decade of tobacco control efforts.},
	pages = {177--195},
	number = {2},
	journaltitle = {Hematology/Oncology Clinics of North America},
	shortjournal = {Hematology/Oncology Clinics of North America},
	author = {Emmons, Karen M. and Kawachi, Ichiro and Barclay, Gillian},
	urldate = {2022-12-23},
