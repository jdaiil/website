	keywords = {Hunger, Food craving, Affect, Diet, Goal-congruent, Healthy eating, {mlVAR}, Network analysis, Stress coping},
	file = {Full Text PDF:C\:\\Users\\d497j944\\Zotero\\storage\\FWGP6KKA\\Pannicke et al. - 2021 - Networks of stress, affect and eating behaviour a.pdf:application/pdf},
}

