@article{foulkes_is_2016,
	title = {Is there heightened sensitivity to social reward in adolescence?},
	volume = {40},
	issn = {0959-4388},
	url = {https://www.sciencedirect.com/science/article/pii/S0959438816300824},
	doi = {10.1016/j.conb.2016.06.016},
	series = {Systems neuroscience},
	abstract = {During adolescence, individuals are particularly susceptible to social influence. One explanation for this is that social stimuli have a heightened reward value at this age. To date, most evidence for heightened social reward in adolescence is found in the animal literature. Human adolescents show increased activation in fronto-striatal brain regions to rewarding social stimuli, but also to negative social stimuli, suggesting that adolescence may be a period of hypersensitivity to all social stimuli. Additional evidence from humans and animals suggest that the presence of others may heighten the value of non-social rewards; these findings should be incorporated into theories of social reward in adolescence.},
	pages = {81--85},
	journaltitle = {Current Opinion in Neurobiology},
	shortjournal = {Current Opinion in Neurobiology},
	author = {Foulkes, Lucy and Blakemore, Sarah-Jayne},
	urldate = {2023-04-04},
