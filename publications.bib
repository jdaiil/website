@article{molloy_hierarchies_2020-1,
	title = {Hierarchies improve individual assessment of temporal discounting behavior.},
	volume = {7},
	issn = {2325-9973, 2325-9965},
	url = {https://doi.apa.org/doi/10.1037/dec0000121},
	doi = {10.1037/dec0000121},
	abstract = {Delay discounting behavior has proven useful in assessing impulsivity across a wide range of populations. As such, accurate estimation of the shape of each individual’s temporal discounting proﬁle is paramount when drawing conclusions about how impulsivity relates to clinical and health outcomes such as gambling, addiction, and obesity. Here, we identify an estimation problem with current methods of assessing temporal discounting behavior and propose a simple solution. First, through a simulation study, we identify types of temporal discounting proﬁles that cannot reliably be estimated. Second, we show how imposing constraints through hierarchical modeling ameliorates these recovery problems. Finally, we apply our solution to a large data set from a temporal discounting task and illustrate the importance of reliable estimation within patient populations. We conclude with a brief discussion on how hierarchical Bayesian methods can aid in model estimation, compensate for small samples, and improve predictions of externalizing psychopathology.},
	pages = {212--224},
	number = {3},
	journaltitle = {Decision},
	shortjournal = {Decision},
	author = {Molloy, M. Fiona and Romeu, Ricardo J. and Kvam, Peter D. and Finn, Peter R. and Busemeyer, Jerome and Turner, Brandon M.},
	urldate = {2024-02-13},
	date = {2020-07},
	langid = {english},
	file = {Molloy et al. - 2020 - Hierarchies improve individual assessment of tempo.pdf:C\:\\Users\\d497j944\\Zotero\\storage\\UB289JI8\\Molloy et al. - 2020 - Hierarchies improve individual assessment of tempo.pdf:application/pdf},
}

