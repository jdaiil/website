	note = {\_eprint: https://onlinelibrary.wiley.com/doi/pdf/10.1002/\%28SICI\%291098-108X\%28199903\%2925\%3A2\%3C169\%3A\%3AAID-{EAT}6\%3E3.0.{CO}\%3B2-B},
