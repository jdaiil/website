@article{fagan_multi-level_2015,
	title = {A multi-level analysis of the impact of neighborhood structural and social factors on adolescent substance use},
	volume = {153},
	issn = {0376-8716},
	url = {https://www.sciencedirect.com/science/article/pii/S0376871615002586},
	doi = {10.1016/j.drugalcdep.2015.05.022},
	abstract = {Background
This paper examined the effects of neighborhood structural (i.e., economic disadvantage, immigrant concentration, residential stability) and social (e.g., collective efficacy, social network interactions, intolerance of drug use, legal cynicism) factors on the likelihood of any adolescent tobacco, alcohol, and marijuana use.
Methods
Analyses drew upon information from the Project on Human Development in Chicago Neighborhoods ({PHDCN}). Data were obtained from a survey of adult residents of 79 Chicago neighborhoods, two waves of interviews with 1657 to 1664 care-givers and youth aged 8 to 16 years, and information from the 1990 U.S. Census Bureau. Hierarchical Bernoulli regression models estimated the impact of neighborhood factors on substance use controlling for individual-level demographic characteristics and psycho-social risk factors.
Results
Few neighborhood factors had statistically significant direct effects on adolescent tobacco, alcohol or marijuana use, although youth living in neighborhoods with greater levels of immigrant concentration were less likely to report any drinking.
Conclusion
Additional theorizing and more empirical research are needed to better understand the ways in which contextual influences affect adolescent substance use and delinquency.},
	pages = {180--186},
	journaltitle = {Drug and Alcohol Dependence},
	shortjournal = {Drug and Alcohol Dependence},
	author = {Fagan, Abigail A. and Wright, Emily M. and Pinchevsky, Gillian M.},
	urldate = {2023-04-04},
	date = {2015-08-01},
	langid = {english},
	keywords = {Adolescent substance use, Multi-level analysis, Neighborhood context},
	file = {ScienceDirect Full Text PDF:C\:\\Users\\d497j944\\Zotero\\storage\\CGL9EUML\\Fagan et al. - 2015 - A multi-level analysis of the impact of neighborho.pdf:application/pdf;ScienceDirect Snapshot:C\:\\Users\\d497j944\\Zotero\\storage\\QVRRB669\\S0376871615002586.html:text/html},
}

