@article{levy_test-retest_2004,
	title = {Test-Retest Reliability of Adolescents’ Self-Report of Substance Use},
	volume = {28},
	issn = {1530-0277},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1097/01.ALC.0000134216.22162.A5},
	doi = {10.1097/01.ALC.0000134216.22162.A5},
	abstract = {Background: Adolescent substance abuse is a serious problem for which effective interventions are needed. To conduct trials of new therapies, investigators need reliable means of identifying potential participants and of measuring outcomes. The objective of this study was to determine the 1-week test-retest reliability of the {CRAFFT} screening test and of the timeline follow-back ({TLFB}) calendar method for measuring alcohol, cannabis, and other drug use. Methods: Ninety-three 12- to 18-year-old patients presenting for routine medical care to three urban adolescent clinics were administered the {CRAFFT} screen in both lifetime and past-year versions and a 90-day {TLFB}. Both measures were completed on the day of the clinic visit and again 1 week later. We computed κ coefficients and the intraclass correlation coefficient ({ICC}) for the {CRAFFT} and computed the {ICC} separately for {TLFB} self-reports of alcohol and cannabis. Results: For the {CRAFFT}, κ for individual items ranged from 0.31 to 0.86, and the {ICC} was 0.93 (95\% confidence interval, 0.90–0.95). However, the total score of the lifetime {CRAFFT} at time 2 was significantly lower than at time 1; there was no difference in time 1 and time 2 total scores for the past-year version. The {ICCs} for past-90-days {TLFB} variables were as follows: drinking days, 0.92; drinks per occasion, 0.87; cannabis days, 0.83; and joints per occasion, 0.76. Past-30-day and past-60-day intervals compared favorably to past-90-day intervals. Conclusions: The {CRAFFT} screen is a reliable means of screening adolescents for substance abuse, although we recommend using the past-year version. The {TLFB} is a reliable method of quantifying adolescents’ alcohol and cannabis use at intervals of 30, 60, or 90 days.},
	pages = {1236--1241},
	number = {8},
	journaltitle = {Alcoholism: Clinical and Experimental Research},
	author = {Levy, Sharon and Sherritt, Lon and Harris, Sion Kim and Gates, Elizabeth C. and Holder, David W. and Kulig, John W. and Knight, John R.},
	urldate = {2025-07-27},
	date = {2004},
	langid = {english},
	note = {\_eprint: https://onlinelibrary.wiley.com/doi/pdf/10.1097/01.{ALC}.0000134216.22162.A5},
	keywords = {Substance-Related Disorders, Adolescence, Alcoholism, Test-Retest Reliability},
	file = {Full Text PDF:C\:\\Users\\d497j944\\Zotero\\storage\\VJXIVK2Z\\Levy et al. - 2004 - Test-Retest Reliability of Adolescents’ Self-Report of Substance Use.pdf:application/pdf;Snapshot:C\:\\Users\\d497j944\\Zotero\\storage\\49Z7Z5FD\\01.ALC.0000134216.22162.html:text/html},
}

@article{pedersen_concurrent_2012,
	title = {Concurrent validity of an online version of the Timeline Followback assessment},
	volume = {26},
	issn = {1939-1501},
	doi = {10.1037/a0027945},
	abstract = {The Timeline Followback ({TLFB}) interview has been used extensively in the assessment of alcohol and other substance use. While this methodology has been validated in multiple formats for multiple behaviors, to date no systematic comparisons have been conducted between the traditional interview format and online versions. The present research employed a randomized within-subjects design to compare interview versus online-based {TLFB} assessments of alcohol and marijuana use among 102 college students. Participants were randomly assigned to receive either the online version first or the in-person interview format first. Participants subsequently completed the second format within 3 days. While we expected few overall differences between formats, we hypothesized that differences might emerge to the extent that participants are more comfortable and willing to answer honestly in an online format, which provides a degree of anonymity. Results were consistent with expectations in suggesting relatively few differences between the online version and the in-person version. Participants did report feeling more comfortable in completing the online version. Moreover, greater discomfort during the in-person assessment was associated with reporting more past-month marijuana use on the online assessment, but reported discomfort did not moderate differences between formats in reported alcohol consumption. ({PsycInfo} Database Record (c) 2022 {APA}, all rights reserved)},
	pages = {672--677},
	number = {3},
	journaltitle = {Psychology of Addictive Behaviors},
	author = {Pedersen, Eric R. and Grow, Joel and Duncan, Sean and Neighbors, Clayton and Larimer, Mary E.},
	date = {2012},
	note = {Place: {US}
Publisher: American Psychological Association},
	keywords = {Alcohol Use, Cannabis Use, Internet, Measurement, Concurrent Validity},
	file = {Accepted Version:C\:\\Users\\d497j944\\Zotero\\storage\\RH3BARS7\\Pedersen et al. - 2012 - Concurrent validity of an online version of the Timeline Followback assessment.pdf:application/pdf;Snapshot:C\:\\Users\\d497j944\\Zotero\\storage\\QGVGQUBA\\doiLanding.html:text/html},
}

