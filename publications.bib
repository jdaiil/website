@article{adams_effects_2021,
	title = {Effects of Acute Alcohol Consumption on Food Intake and Pictorial Stroop Response to High-Calorie Food Cues},
	volume = {56},
	rights = {https://academic.oup.com/journals/pages/open\_access/funder\_policies/chorus/standard\_publication\_model},
