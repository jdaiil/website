@article{dwyer_large-scale_2014,
	title = {Large-Scale Brain Network Dynamics Supporting Adolescent Cognitive Control},
	volume = {34},
	rights = {Copyright © 2014 the authors 0270-6474/14/3414096-13\$15.00/0},
	issn = {0270-6474, 1529-2401},
	url = {https://www.jneurosci.org/content/34/42/14096},
	doi = {10.1523/JNEUROSCI.1634-14.2014},
	abstract = {Adolescence is a time when the ability to engage cognitive control is linked to crucial life outcomes. Despite a historical focus on prefrontal cortex functioning, recent evidence suggests that differences between individuals may relate to interactions between distributed brain regions that collectively form a cognitive control network ({CCN}). Other research points to a spatially distinct and functionally antagonistic system—the default-mode network ({DMN})—which typically deactivates during performance of control tasks. This literature implies that individual differences in cognitive control are determined either by activation or functional connectivity of {CCN} regions, deactivation or functional connectivity of {DMN} regions, or some combination of both. We tested between these possibilities using a multilevel {fMRI} characterization of {CCN} and {DMN} dynamics, measured during performance of a cognitive control task and during a task-free resting state, in 73 human adolescents. Better cognitive control performance was associated with (1) reduced activation of {CCN} regions, but not deactivation of the {DMN}; (2) variations in task-related, but not resting-state, functional connectivity within a distributed network involving both the {CCN} and {DMN}; (3) functional segregation of core elements of these two systems; and (4) task-dependent functional integration of a set of peripheral nodes into either one network or the other in response to prevailing stimulus conditions. These results indicate that individual differences in adolescent cognitive control are not solely attributable to the functioning of any single region or network, but are instead dependent on a dynamic and context-dependent interplay between the {CCN} and {DMN}.},
	pages = {14096--14107},
	number = {42},
	journaltitle = {Journal of Neuroscience},
	shortjournal = {J. Neurosci.},
	author = {Dwyer, Dominic B. and Harrison, Ben J. and Yücel, Murat and Whittle, Sarah and Zalesky, Andrew and Pantelis, Christos and Allen, Nicholas B. and Fornito, Alex},
	urldate = {2023-04-03},
	date = {2014-10-15},
	langid = {english},
	pmid = {25319705},
	note = {Publisher: Society for Neuroscience
Section: Articles},
	keywords = {{fMRI}, adolescence, cognitive control, functional connectivity, graph theory, modularity},
	file = {Full Text PDF:C\:\\Users\\d497j944\\Zotero\\storage\\FCVASKHF\\Dwyer et al. - 2014 - Large-Scale Brain Network Dynamics Supporting Adol.pdf:application/pdf},
}

@incollection{luna_developmental_2009,
	title = {Developmental Changes in Cognitive Control through Adolescence},
	volume = {37},
	url = {https://www.sciencedirect.com/science/article/pii/S0065240709037069},
	abstract = {Development refers to the mechanisms of change that ultimately lead to maturity in adulthood. Although much is known about the significant advances that occur in infancy and childhood, relatively less is known of the mechanisms that support the later parts of development in adolescence as mature-level behavior is approached. Early development involves the acquisition of abilities that significantly change behavior, but as maturity is reached, the changes are more subtle and involve the sophistication of abilities. This process begins in adolescence and can be conceptualized as occurring at the bend in the curve of development just before the curve flattens representing adult stability.},
