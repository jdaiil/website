	number = {11},
	journaltitle = {Current diabetes reports},
	shortjournal = {Curr Diab Rep},
	author = {Lanoye, Autumn and Brown, Kristal L. and {LaRose}, Jessica G.},
	urldate = {2025-07-16},
	date = {2017-10-02},
	pmid = {28971312},
	pmcid = {PMC5679785},
	file = {Accepted Version:C\:\\Users\\d497j944\\Zotero\\storage\\FSWE77WB\\Lanoye et al. - 2017 - The Transition into Young Adulthood A Critical Period for Weight Control.pdf:application/pdf},
}

@article{mccarty_longitudinal_2009,
	title = {Longitudinal associations among depression, obesity and alcohol use disorders in young adulthood},
	volume = {31},
	issn = {0163-8343},
	url = {https://www.sciencedirect.com/science/article/pii/S0163834309001005},
	doi = {10.1016/j.genhosppsych.2009.05.013},
	abstract = {Objective
This study examined concurrent and prospective relations between clinical depression, obesity and alcohol use disorders during young adulthood to better understand common etiology and the progression of co-occurrence.
Method
Participants were 776 young adults (393 males and 383 females) who were interviewed at ages 24, 27 and 30 years with assessment of past-year major depressive episode, past-year alcohol abuse or dependence disorder, and obesity. Longitudinal path analyses were conducted separately for women and men, controlling for income and including stability of each of these outcomes.
Results
Among women, depression was positively associated with later alcohol use disorders (ages 27 to 30: {OR}=3.11), and alcohol use disorders prospectively predicted obesity (ages 24 to 27: {OR}=3.84). Obesity predicted depression from ages 27 to 30 among women ({OR}=2.14), but was protective against depression for males ({OR}=0.31).
Conclusions
Results show that depression, obesity and alcohol use disorders are interrelated conditions for women. A greater understanding of reasons underlying the co-occurrence of these conditions would benefit prevention and intervention efforts.},
	pages = {442--450},
	number = {5},
	journaltitle = {General Hospital Psychiatry},
	shortjournal = {General Hospital Psychiatry},
	author = {{McCarty}, Carolyn A. and Kosterman, Rick and Mason, W. Alex and {McCauley}, Elizabeth and Hawkins, J. David and Herrenkohl, Todd I. and Lengua, Liliana J.},
	urldate = {2025-07-16},
	date = {2009-09-01},
	keywords = {Obesity, Young adults, Depression, Comorbidity, Alcohol abuse},
	file = {ScienceDirect Full Text PDF:C\:\\Users\\d497j944\\Zotero\\storage\\46C7ZC7H\\McCarty et al. - 2009 - Longitudinal associations among depression, obesity and alcohol use disorders in young adulthood.pdf:application/pdf;ScienceDirect Snapshot:C\:\\Users\\d497j944\\Zotero\\storage\\Q5CNLT3Y\\S0163834309001005.html:text/html},
