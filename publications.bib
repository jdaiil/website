	file = {PubMed Central Full Text PDF:C\:\\Users\\d497j944\\Zotero\\storage\\9QI6GSD5\\Howard et al. - 2021 - Examining the ecological validity of the Power of Food Scale.pdf:application/pdf},
}

@article{parker_associations_2022-2,
	title = {Associations of sleep with food cravings and loss‐of‐control eating in youth: An ecological momentary assessment study.},
	volume = {17},
	issn = {2047-6302},
	url = {https://research.ebsco.com/linkprocessor/plink?id=c3dc46a0-4e16-30c1-bc5b-b937dae8b171},
	doi = {10.1111/ijpo.12851},
	shorttitle = {Associations of sleep with food cravings and loss‐of‐control eating in youth},
	abstract = {Summary: Background: Inconsistent sleep patterns may promote excess weight gain by increasing food cravings and loss‐of‐control ({LOC})‐eating; however, these relationships have not been elucidated in youth. Objective: We tested whether sleep duration and timing were associated with food cravings and {LOC}‐eating. Method: For 14 days, youths wore actigraphy monitors to assess sleep and reported severity of food cravings and {LOC}‐eating using ecological momentary assessment. Generalized linear mixed models tested the associations between weekly and nightly shifts in facets of sleep (i.e., duration, onset, midpoint, and waketime) and next‐day food cravings and {LOC}‐eating. Models were re‐run adjusting for relevant covariates (e.g., age, sex, adiposity). Results: Among 48 youths (12.88 ± 2.69 years, 68.8\% female, 33.3\% with overweight/obesity), neither weekly nor nightly facets of sleep were significantly associated with food cravings (ps = 0.08–0.93). Youths with shorter weekly sleep duration (est. ß = −0.31, p = 0.004), earlier weekly midpoints (est. ß = −0.47, p = 0.010) and later weekly waketimes (est. ß = 0.49, p = 0.010) reported greater {LOC}‐eating severity; findings persisted in adjusted models. Conclusions: In youth, weekly, but not nightly, shifts in multiple facets of sleep were associated with {LOC}‐eating severity; associations were not significant for food cravings. Sleep should be assessed as a potentially modifiable target in paediatric {LOC}‐eating and obesity prevention programs.},
	pages = {1--10},
	number = {2},
	journaltitle = {Pediatric Obesity},
	shortjournal = {Pediatric Obesity},
	author = {Parker, Megan N. and {LeMay}‐Russell, Sarah and Schvey, Natasha A. and Crosby, Ross D. and Ramirez, Eliana and Kelly, Nichole R. and Shank, Lisa M. and Byrne, Meghan E. and Engel, Scott G. and Swanson, Taylor N. and Djan, Kweku G. and Kwarteng, Esther A. and Faulkner, Loie M. and Zenno, Anna and Brady, Sheila M. and Yanovski, Susan Z. and Tanofsky‐Kraff, Marian and Yanovski, Jack A.},
	urldate = {2025-01-11},
	date = {2022-02-01},
	note = {Publisher: Wiley-Blackwell},
	keywords = {{ACTIGRAPHY}, {AGE} distribution, {CONTROL} (Psychology), {DESCRIPTIVE} statistics, {DESIRE}, {ECOLOGICAL} research, {FOOD} habits, {OBESITY}, {SEX} distribution, {SLEEP}, {WEARABLE} technology},
	file = {Full text PDF:C\:\\Users\\d497j944\\Zotero\\storage\\TIJ8KPWA\\Parker et al. - 2022 - Associations of sleep with food cravings and loss‐of‐control eating in youth An ecological momentar.pdf:application/pdf},
}

