	file = {PDF:C\:\\Users\\d497j944\\Zotero\\storage\\GXZ682XM\\McGowan et al. - 2022 - Daily sensation-seeking and urgency in young adults Examining associations with alcohol use and sel.pdf:application/pdf},
}

@article{riley_predictors_2021,
	title = {Predictors of health behaviors during a college national championship sports event: A daily diary study},
	volume = {69},
	issn = {0744-8481, 1940-3208},
	url = {https://www.tandfonline.com/doi/full/10.1080/07448481.2020.1719110},
	doi = {10.1080/07448481.2020.1719110},
	shorttitle = {Predictors of health behaviors during a college national championship sports event},
	abstract = {Objective: Few studies have examined relations between college sporting events and maladaptive health behaviors among non-athlete college students. Participants: 97 college students.
Methods: Completed nightly surveys (alcohol, eating, physical activity, sexual risk taking, smoking) for 11 days around a National Championship game. Results: Baseline stress and rumination was related to worse health behavior; mindfulness was related to better health behavior. Hierarchical linear modeling showed that all maladaptive health behaviors significantly increased the day of the sporting event compared to individuals’ baseline levels. Rumination significantly predicted a spike in alcohol use and sexual risk taking behavior on the day of the Championship game.
Conclusions: Risk factors for maladaptive health behaviors include stress and rumination, while mindfulness is protective. Interventions may work to make sports events on campus safer for students (e.g., condoms, reminder emails, mindfulness interventions for at risk groups); more research is needed.},
	pages = {928--936},
