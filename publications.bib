	file = {Full Text PDF:C\:\\Users\\d497j944\\Zotero\\storage\\KUHI72AA\\Ritchie et al. - 2022 - The Effect of Alcohol Cue Exposure on Tobacco-Related Cue Reactivity A Systematic Review.pdf:application/pdf;Snapshot:C\:\\Users\\d497j944\\Zotero\\storage\\GI8283ZJ\\6137281.html:text/html},
