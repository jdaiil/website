	langid = {english},
	note = {\_eprint: https://onlinelibrary.wiley.com/doi/pdf/10.1038/oby.2010.20},
	file = {Full Text PDF:C\:\\Users\\d497j944\\Zotero\\storage\\VAUXAKAH\\Giesen et al. - 2010 - Will Work for Snack Food The Association of BMI a.pdf:application/pdf;Full Text PDF:C\:\\Users\\d497j944\\Zotero\\storage\\9S4AT67H\\Giesen et al. - 2010 - Will Work for Snack Food The Association of BMI and Snack Reinforcement.pdf:application/pdf;Snapshot:C\:\\Users\\d497j944\\Zotero\\storage\\EXRTRZ9J\\oby.2010.html:text/html;Snapshot:C\:\\Users\\d497j944\\Zotero\\storage\\U4CHMBXL\\oby.2010.html:text/html},
