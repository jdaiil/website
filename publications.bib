	shorttitle = {Poly-victimization and opioid use during late adolescence and young adulthood},
	abstract = {This study shows the importance of including trauma-related characteristics and highlights important health behavior disparities that differentiate class membership. The study also shows differential risk of opioid use associated with victimization and trauma-related characteristics and the importance of selfefﬁcacy and neighborhood cohesion in mitigating these risks.},
