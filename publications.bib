	file = {Dora et al. - 2022 - The daily association between affect and alcohol u.pdf:C\:\\Users\\d497j944\\Zotero\\storage\\8N5TUKHZ\\Dora et al. - 2022 - The daily association between affect and alcohol u.pdf:application/pdf},
