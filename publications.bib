	langid = {english},
	note = {Publisher: {SAGE} Publications Inc},
	file = {Accepted Version:C\:\\Users\\d497j944\\Zotero\\storage\\4AJRNBNE\\Yarkoni and Westfall - 2017 - Choosing Prediction Over Explanation in Psychology.pdf:application/pdf},
}

@article{cearns_recommendations_2019,
	title = {Recommendations and future directions for supervised machine learning in psychiatry},
	volume = {9},
	rights = {2019 The Author(s)},
