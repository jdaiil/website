Publisher: American Psychological Association},
	keywords = {Alcohol Use, Social Influences, Imitation (Learning), Interpersonal Interaction, Sociability},
	file = {Snapshot:C\:\\Users\\d497j944\\Zotero\\storage\\AA7BDK4K\\1985-22560-001.html:text/html},
