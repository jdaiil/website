}

@article{bickel_reinforcer_2017,
	title = {Reinforcer Pathology: The Behavioral Economics of Abuse Liability Testing},
	volume = {101},
	rights = {http://onlinelibrary.wiley.com/{termsAndConditions}\#vor},
	issn = {0009-9236, 1532-6535},
	url = {https://ascpt.onlinelibrary.wiley.com/doi/10.1002/cpt.443},
