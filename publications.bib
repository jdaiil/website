	journaltitle = {International Journal of Eating Disorders},
	shortjournal = {Int. J. Eat. Disord.},
	author = {Lafay, Lionel and Thomas, Fr�d�rique and Mennen, Louise and Charles, Marie Aline and Eschwege, Eveline and Borys, Jean-Michel and {the Fleurbaix Laventie Ville Sant� study group}},
