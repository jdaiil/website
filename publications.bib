@article{wallwork_searching_2012,
	title = {Searching for a consensus five-factor model of the Positive and Negative Syndrome Scale for schizophrenia},
	volume = {137},
	issn = {0920-9964},
	url = {https://www.sciencedirect.com/science/article/pii/S0920996412000564},
	doi = {10.1016/j.schres.2012.01.031},
	abstract = {Although the developers of the Positive and Negative Syndrome Scale ({PANSS}) grouped items into three subscales, factor analyses indicate that a five-factor model better characterizes {PANSS} data. However, lack of consensus on which model to use limits the comparability of {PANSS} variables across studies. We counted “votes” from published factor analyses to derive consensus models. One of these combined superior fit in our Caucasian sample (n=458, {CFI}=.970), and in distinct Japanese sample (n=164, {CFI}=.964), relative to the original three-subscale model, with a sorting of items into factors that was highly consistent across the studies reviewed.},
	pages = {246--250},
	number = {1},
	journaltitle = {Schizophrenia Research},
	shortjournal = {Schizophrenia Research},
	author = {Wallwork, R. S. and Fortgang, R. and Hashimoto, R. and Weinberger, D. R. and Dickinson, D.},
	urldate = {2025-08-30},
	date = {2012-05-01},
	keywords = {Cognition, Schizophrenia, {PANSS}, Symptoms},
	file = {Accepted Version:C\:\\Users\\d497j944\\Zotero\\storage\\CRBCMU9R\\Wallwork et al. - 2012 - Searching for a consensus five-factor model of the Positive and Negative Syndrome Scale for schizoph.pdf:application/pdf;ScienceDirect Snapshot:C\:\\Users\\d497j944\\Zotero\\storage\\4V7LR55H\\S0920996412000564.html:text/html},
}

@article{stein_factor_2020,
	title = {Factor analyses of multidimensional symptoms in a large group of patients with major depressive disorder, bipolar disorder, schizoaffective disorder and schizophrenia},
	volume = {218},
	issn = {0920-9964},
	url = {https://www.sciencedirect.com/science/article/pii/S0920996420301146},
	doi = {10.1016/j.schres.2020.03.011},
	abstract = {Background
There is an ongoing discussion about which neurobiological correlates or symptoms separate the major psychoses (i.e. Major Depressive Disorder {MDD}, Bipolar Disorder {BD}, and Schizophrenia {SZ}). Psychopathological factor analyses within one of these disorders have resulted in models including one to five factors. Factor analyses across the major psychoses using a comprehensive set of psychopathological scales in the same patients are lacking. It is further unclear, whether hierarchical or unitarian models better summarize phenomena.
Method
Patients (n = 1182) who met {DSM}-{IV} criteria for {MDD}, {BD}, {SZ} or schizoaffective disorder were assessed with the {SANS}, {SAPS}, {HAMA}, {HAM}-D, and {YMRS}. The sample was split into two and analyzed using explorative and confirmatory factor analyses to extract psychopathological factors independent of diagnosis.
Results
In the exploratory analysis of sample 1 (n = 593) we found 5 factors. The confirmatory analysis using sample 2 (n = 589) confirmed the 5-factor model (χ2 = 1287.842, df = 571, p {\textless} .0001: {CFI} = 0.932; {RMSEA} = 0.033). The 5-factors were depression, negative syndrome, positive formal thought disorder, paranoid-hallucinatory syndrome, and increased appetite. Increased appetite was not related to medication. None of the factors was specific for one diagnosis. Second order factor analysis revealed two higher order factors: negative/affective (I) and positive symptoms ({II}).
Conclusion
This is the first study delineating psychopathological factors in a large group of patients across the spectrum of affective and psychotic disorders. In future neurobiological studies, we should consider transdiagnostic syndromes besides the traditional diagnoses.},
	pages = {38--47},
	journaltitle = {Schizophrenia Research},
	shortjournal = {Schizophrenia Research},
	author = {Stein, Frederike and Lemmer, Gunnar and Schmitt, Simon and Brosch, Katharina and Meller, Tina and Fischer, Elena and Kraus, Cynthia and Lenhard, Lutz and Köhnlein, Birgit and Murata, Harumi and Bäcker, Achim and Müller, Matthias and Franz, Michael and Förster, Katharina and Meinert, Susanne and Enneking, Verena and Koch, Katharina and Grotegerd, Dominik and Nagels, Arne and Nenadić, Igor and Dannlowski, Udo and Kircher, Tilo and Krug, Axel},
	urldate = {2025-08-30},
	date = {2020-04-01},
	keywords = {Transdiagnostic, Psychopathology, Hierarchical model, Factor analysis, Symptoms, Major psychoses},
	file = {ScienceDirect Snapshot:C\:\\Users\\d497j944\\Zotero\\storage\\V2989GBQ\\S0920996420301146.html:text/html},
}

