}

@article{white_reward_1989,
	title = {Reward or reinforcement: What's the difference?},
	volume = {13},
	issn = {0149-7634},
	url = {https://www.sciencedirect.com/science/article/pii/S0149763489800284},
	doi = {10.1016/S0149-7634(89)80028-4},
	series = {The Neural Basis of Reward and Reinforcement: A Conference in Honour of Peter M. Milner},
	shorttitle = {Reward or reinforcement},
	abstract = {The histories of the terms “reward” and “reinforcement” are reviewed to show the difference in their origins. Reward refers to the fact that certain environmental stimuli have the property of eliciting approach responses. Evidence suggests that the ventral striatum (nucleus accumbens area) is central to the mediation of this behavior. Reinforcement refers to the tendency of certain stimuli to strengthen learned stimulus-response tendencies. The dorsolateral striatum appears to be central to the mediation of this behavior. Neuroanatomical and neurochemical data are adduced suggesting that reward may be mediated by a neural circuit including the neostriatal patch system, together with the hippocampus, limbic system (amygdala, prefrontal cortex) and ventral pallidum. The evidence also suggests that reinforcement, in the form of dopamine release in the striatal matrix, acts to promote the consolidation of sensori-motor associations. Thus, the matrix may mediate stimulus-response memory as part of a circuit including the cerebral cortex, substantia nigra pars reticulata and its projections to thalamic and brainstem motor areas.},
	pages = {181--186},
	number = {2},
	journaltitle = {Neuroscience \& Biobehavioral Reviews},
	shortjournal = {Neuroscience \& Biobehavioral Reviews},
	author = {White, Norman M.},
	urldate = {2025-07-19},
	date = {1989-06-01},
	keywords = {Reinforcement, Reward},
	file = {ScienceDirect Snapshot:C\:\\Users\\d497j944\\Zotero\\storage\\6RNMT2WX\\S0149763489800284.html:text/html},
}

@article{a_carr_reinforcement_2011,
	title = {Reinforcement Pathology and Obesity},
	volume = {4},
	issn = {1874-4737},
	url = {http://www.eurekaselect.com/openurl/content.php?genre=article&issn=1874-4737&volume=4&issue=3&spage=190},
	doi = {10.2174/1874473711104030190},
	abstract = {Obesity is, in part, a result of positive energy balance or energy intake exceeding physiological needs. Excess energy intake is determined by a series of food choices over time. These choices involve both motivational and executive function processes. Problems arise when there is excessive motivation to eat and low impulse control, a situation we have termed reinforcement pathology. Motivational and executive function processes have also been implicated in the development of drug dependence and addiction. In this review we discuss the application of reinforcement pathology to obesity, and implications of this approach for obesity treatment.},
	pages = {190--196},
	number = {3},
	journaltitle = {Current Drug Abuse Reviewse},
	shortjournal = {{CDAR}},
	author = {A. Carr, Katelyn and Oluyomi Daniel, Tinuke and Lin, Henry and H. Epstein, Leonard},
	urldate = {2025-07-20},
