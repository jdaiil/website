	keywords = {Academic effort, college, heavy alcohol use, skipping class},
	file = {Full Text PDF:C\:\\Users\\d497j944\\Zotero\\storage\\KYBGBTXX\\Allen et al. - 2022 - High-risk alcohol use behavior and daily academic effort among college students.pdf:application/pdf},
