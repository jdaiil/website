@article{halvorson_measuring_2024,
	title = {Measuring loneliness in everyday life.},
	volume = {10},
	issn = {2332-2179, 2332-2136},
	url = {https://doi.apa.org/doi/10.1037/tps0000438},
	doi = {10.1037/tps0000438},
	abstract = {To understand what causes people to feel lonely in everyday life, valid and reliable methods of assessing momentary loneliness are needed. The results from this study show that using multiple questions to assess loneliness outperforms using a single question but that using a single question is a valid approximation in settings where brevity of assessment instruments is a priority (e.g., in clinical settings and naturalistic observational studies). The results from this study also suggest that, while some people are more susceptible to loneliness than others, most people experience momentary loneliness from time to time.},
	pages = {331--345},
	number = {3},
	journaltitle = {Translational Issues in Psychological Science},
	shortjournal = {Translational Issues in Psychological Science},
	author = {Halvorson, Max A. and Kuczynski, Adam M.},
	urldate = {2026-01-02},
