@article{boswell_food_2016,
	title = {Food cue reactivity and craving predict eating and weight gain: a meta-analytic review},
	volume = {17},
	rights = {© 2015 World Obesity},
	issn = {1467-789X},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1111/obr.12354},
	doi = {10.1111/obr.12354},
	shorttitle = {Food cue reactivity and craving predict eating and weight gain},
	abstract = {According to learning-based models of behavior, food cue reactivity and craving are conditioned responses that lead to increased eating and subsequent weight gain. However, evidence supporting this relationship has been mixed. We conducted a quantitative meta-analysis to assess the predictive effects of food cue reactivity and craving on eating and weight-related outcomes. Across 69 reported statistics from 45 published reports representing 3,292 participants, we found an overall medium effect of food cue reactivity and craving on outcomes (r = 0.33, p {\textless} 0.001; approximately 11\% of variance), suggesting that cue exposure and the experience of craving significantly influence and contribute to eating behavior and weight gain. Follow-up tests revealed a medium effect size for the effect of both tonic and cue-induced craving on eating behavior (r = 0.33). We did not find significant differences in effect sizes based on body mass index, age, or dietary restraint. However, we did find that visual food cues (e.g. pictures and videos) were associated with a similar effect size to real food exposure and a stronger effect size than olfactory cues. Overall, the present findings suggest that food cue reactivity, cue-induced craving and tonic craving systematically and prospectively predict food-related outcomes. These results have theoretical, methodological, public health and clinical implications.},
	pages = {159--177},
	number = {2},
	journaltitle = {Obesity Reviews},
	author = {Boswell, Rebecca G. and Kober, Hedy},
	urldate = {2023-11-16},
	date = {2016},
	langid = {english},
	note = {\_eprint: https://onlinelibrary.wiley.com/doi/pdf/10.1111/obr.12354},
	keywords = {Craving, eating behavior, food, weight gain, meta-analysis, cue reactivity},
	file = {Full Text PDF:C\:\\Users\\d497j944\\Zotero\\storage\\GNLV7RE8\\Boswell and Kober - 2016 - Food cue reactivity and craving predict eating and.pdf:application/pdf;Snapshot:C\:\\Users\\d497j944\\Zotero\\storage\\HCLE5XVC\\obr.html:text/html},
}

@article{sun_regulating_2020-1,
