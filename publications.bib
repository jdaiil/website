}

@article{kuczynski_characterizing_2024,
	title = {Characterizing the momentary association between loneliness, depression, and social interactions: Insights from an ecological momentary assessment study},
	volume = {360},
	issn = {01650327},
	url = {https://linkinghub.elsevier.com/retrieve/pii/S0165032724008929},
	doi = {10.1016/j.jad.2024.05.148},
	shorttitle = {Characterizing the momentary association between loneliness, depression, and social interactions},
	abstract = {Evidence suggests that loneliness causes people to feel more depressed. It is unknown, however, why this association occurs and whether momentary versus chronic experiences of loneliness are implicated. Theoretical accounts suggest that momentary feelings of loneliness produce two competing motivations: social reaffiliation and social withdrawal. Social affiliation is protective against depression; social withdrawal, in contrast, is a risk factor. Thus, engaging in frequent and high-quality interactions following experiences of loneliness may protect against subsequent depression. We tested this hypothesis using a random-interval experience sampling design (5x/day/day, 14 days; Nobs = 6568) with a racially/ethnically diverse sample of adults with elevated depression symptoms (N = 102). Momentary loneliness was associated with depressed mood at the same time point and {\textasciitilde}2.5h and {\textasciitilde}5h later. Frequency and quality of social interaction did not moderate these associations. Findings suggest that momentary feelings of loneliness may be an important target for clinical intervention.},
	pages = {376--386},
	journaltitle = {Journal of Affective Disorders},
	shortjournal = {Journal of Affective Disorders},
	author = {Kuczynski, Adam M. and Piccirillo, Marilyn L. and Dora, Jonas and Kuehn, Kevin S. and Halvorson, Max A. and King, Kevin M. and Kanter, Jonathan W.},
	urldate = {2026-01-02},
	date = {2024-09},
	langid = {english},
	file = {PDF:C\:\\Users\\d497j944\\Zotero\\storage\\6SCGJXU4\\Kuczynski et al. - 2024 - Characterizing the momentary association between loneliness, depression, and social interactions In.pdf:application/pdf},
}

@article{kopelovich_preliminary_2025,
	title = {Preliminary investigation of an artificial intelligence-based cognitive behavioral therapy training tool.},
	volume = {62},
	rights = {https://creativecommons.org/licenses/by-nc-nd/4.0},
	issn = {1939-1536, 0033-3204},
	url = {https://doi.apa.org/doi/10.1037/pst0000550},
	doi = {10.1037/pst0000550},
	abstract = {Clinical Impact Statement Question: How will practitioners in a Community Behavioral Health setting use and appraise a fully asynchronous artiﬁcial intelligence- ({AI}-) enhanced training tool in cognitive behavioral therapy? Findings: Participants accessed the tool on a near-daily basis; however, 43\% of learners did not utilize the tool’s {AI}-enabled feedback feature. Participants reported high levels of satisfaction, usability, acceptability, appropriateness, and feasibility. The degree of engagement with the tool positively correlated with these outcomes. Meaning: Practitioners will engage with and may beneﬁt from {AI}-enhanced training, but individual- and system-level supports are needed to optimize engagement with the tool. Next Steps: Future research and deployment efforts should focus on factors associated with engagement and evaluate the effects of training on learner and patient outcomes.},
	pages = {12--21},
	number = {1},
	journaltitle = {Psychotherapy},
	shortjournal = {Psychotherapy},
	author = {Kopelovich, Sarah L. and Slevin, Roisín and Brian, Rachel M. and Shepard, Victoria and Baldwin, Scott A. and Ben-Zeev, Dror and Tanana, Mike and Imel, Zac},
