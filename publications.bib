	file = {Valdez et al. - 2019 - Translating research to support practitioners in a.pdf:C\:\\Users\\d497j944\\Zotero\\storage\\7H3FLQRE\\Valdez et al. - 2019 - Translating research to support practitioners in a.pdf:application/pdf},
